<idea-plugin>
    <id>com.protean.copilot</id>
    <name>Protean Copilot</name>
    <vendor email="dev@protean.local" url="https://example.com">Protean</vendor>

    <description><![CDATA[
        Protean Copilot is a programming assistant plugin skeleton for IntelliJ IDEA.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="terminal-features.xml">org.jetbrains.plugins.terminal</depends>
    <depends optional="true" config-file="java-features.xml">com.intellij.java</depends>

    <resource-bundle>messages.ProteanCopilotBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="Protean Copilot"
            anchor="right"
            factoryClass="com.protean.copilot.ui.ProteanToolWindow" />

        <postStartupActivity implementation="com.protean.copilot.startup.ProteanStartupActivity" />
        <postStartupActivity implementation="com.protean.copilot.startup.BridgePrewarmActivity" />

        <statusBarWidgetFactory
            id="ProteanCopilot.StatusBar"
            implementation="com.protean.copilot.statusbar.ProteanStatusBarWidgetFactory" />

        <notificationGroup
            id="ProteanCopilot Notifications"
            displayType="BALLOON" />
    </extensions>

    <actions>
        <action
            id="ProteanCopilot.OpenToolWindow"
            class="com.protean.copilot.actions.OpenToolWindowAction"
            text="Open Protean Copilot"
            description="Open the Protean Copilot tool window" />

        <group
            id="ProteanCopilot.Menu"
            text="Protean Copilot"
            popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last" />
            <action
                id="ProteanCopilot.ExplainSelection"
                class="com.protean.copilot.actions.ExplainSelectionAction"
                text="Explain Selection"
                description="Collect the current selection or file for Protean Copilot" />
            <separator />
            <reference ref="ProteanCopilot.OpenToolWindow" />
        </group>
    </actions>
</idea-plugin>
